MCP_PORT=3101

# Main backend: browser-use with OpenAI-compatible provider settings
# These values use MiniMax through its OpenAI-compatible API.
LLM_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_TIMEOUT_SECONDS=90
MINIMAX_MAX_RETRIES=2
BROWSER_USE_MAX_STEPS=12

# Secondary backend: local Playwright MCP process
PLAYWRIGHT_MCP_COMMAND=npx
PLAYWRIGHT_MCP_ARGS=@playwright/mcp@latest
PLAYWRIGHT_MCP_TIMEOUT_SECONDS=45
PLAYWRIGHT_HEADLESS=true
