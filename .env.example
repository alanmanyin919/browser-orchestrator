# Browser Orchestrator Environment Configuration
# Copy this to .env and fill in your values

# ===================
# Playwright MCP Config
# ===================
PLAYWRIGHT_MCP_URL=http://localhost:3100
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=true

# ===================
# Better Browser Use Config
# ===================
BROWSER_USE_API_URL=http://localhost:8000
BROWSER_USE_MAX_STEPS=10

# ===================
# Router Config
# ===================
PRIMARY_TIMEOUT_SECONDS=30
FALLBACK_TIMEOUT_SECONDS=60
MAX_RETRIES=2

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
LOG_FILE=./logs/browser-orchestrator.log

# ===================
# MCP Server
# ===================
MCP_HOST=0.0.0.0
MCP_PORT=3101
